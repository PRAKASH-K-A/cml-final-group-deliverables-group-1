{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven: Compile & Run EnvCheck",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "compile",
                "exec:java",
                "-Dexec.mainClass=com.stocker.EnvCheck"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$tsc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
